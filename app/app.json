{
  "expo": {
    "name": "Luxai",
    "slug": "espelhoia",
    "version": "0.1.2",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/brand/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.espelhoia.app",
      "infoPlist": {
        "NSCameraUsageDescription": "O Luxai usa a câmera para avaliar seu look e dar feedback personalizado.",
        "NSMicrophoneUsageDescription": "Necessário para acessar a câmera no iOS."
      }
    },
    "android": {
      "package": "com.espelhoia.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-icon.png",
        "backgroundColor": "#333333"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/splash.png",
          "imageWidth": 1242,
          "resizeMode": "contain",
          "backgroundColor": "#333333"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "O Luxai usa a câmera para avaliar seu look.",
          "enableMicrophonePermission": false
        }
      ],
      "react-native-fast-tflite",
      "expo-audio"
    ],
    "scheme": "luxai",
    "experiments": {
      "typedRoutes": true
    }
  }
}
