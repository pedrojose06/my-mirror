{
  "expo": {
    "name": "EspelhoIA",
    "slug": "espelhoia",
    "version": "0.1.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.espelhoia.app",
      "infoPlist": {
        "NSCameraUsageDescription": "O EspelhoIA usa a câmera para avaliar seu look e dar feedback personalizado.",
        "NSMicrophoneUsageDescription": "Necessário para acessar a câmera no iOS."
      }
    },
    "android": {
      "package": "com.espelhoia.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "O EspelhoIA usa a câmera para avaliar seu look.",
          "enableMicrophonePermission": false
        }
      ],
      "react-native-fast-tflite",
      "expo-audio"
    ],
    "scheme": "espelhoia",
    "experiments": {
      "typedRoutes": true
    }
  }
}
