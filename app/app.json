{
  "expo": {
    "name": "Luxai",
    "slug": "espelhoia",
    "version": "0.3.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/brand/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.luxai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "O Luxai usa a câmera para avaliar seu look e dar feedback personalizado.",
        "NSMicrophoneUsageDescription": "Necessário para acessar a câmera no iOS."
      }
    },
    "android": {
      "package": "com.luxai.app",
      "versionCode": 26,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-icon.png",
        "backgroundColor": "#8A2BE2"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/splash-native.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#7d28cf"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "O Luxai usa a câmera para avaliar seu look.",
          "enableMicrophonePermission": false
        }
      ],
      "react-native-fast-tflite",
      "expo-audio",
      "expo-web-browser",
      "./plugins/withRemoveForegroundService"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/brand/icon.png"
    },
    "scheme": "luxai",
    "experiments": {
      "typedRoutes": true
    },
    "owner": "pedrojose06",
    "extra": {
      "eas": {
        "projectId": "11dde444-29d0-4677-be77-782be492f561"
      }
    }
  }
}
