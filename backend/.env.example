# ---------------------------------------------------------------------------
# Keys do Gemini por estado de login (https://aistudio.google.com/apikey)
# ---------------------------------------------------------------------------
# LOGADO (premium): key de AVALIAÇÃO (avaliação + sugestões). Também é o
# fallback caso TTS/FREE não estejam definidas (setup de chave única).
GEMINI_API_KEY=
# LOGADO (premium): key da VOZ neural (TTS). Se vazio, cai na GEMINI_API_KEY.
GEMINI_TTS_API_KEY=
# DESLOGADO (free-tier): key usada quando NÃO há login. Se vazio, cai na
# GEMINI_API_KEY. <-- A NOVA KEY FREE VAI AQUI.
GEMINI_API_KEY_FREE=

# Verificação de login no servidor (valores PÚBLICOS do Supabase). Sem eles,
# toda requisição é tratada como deslogada (free) por segurança.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Opcional: trocar o modelo (padrão: gemini-flash-lite-latest, que roda no free tier)
# GEMINI_MODEL=gemini-flash-lite-latest
# Modo mock (avaliação falsa, sem custo/sem key). Use "true" para testar.
MOCK_AI=true
